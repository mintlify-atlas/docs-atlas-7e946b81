  "keyFeatures": [
    "ISO 27001:2022 Clauses 4-10 compliance tracking with hierarchical requirement management",
    "Annex A Statement of Applicability (SoA) with 93 ISO 27002:2022 controls",
    "Risk assessment matrix with inherent/residual risk calculation and heat map visualization",
    "Asset inventory management with CIA (Confidentiality, Integrity, Availability) valuation",
    "Internal audit module based on ISO 19011 with findings and PAC tracking",
    "Evidence and document library with version control and clause linking",
    "Business Continuity Planning (BCP/DRP) with Business Impact Analysis",
    "Executive security metrics dashboard with KPIs, charts and PDF export",
    "Multi-tenant B2B architecture for GRC agencies managing multiple client ISMS",
    "Role-based access control (CISO, Auditor, Owner) with read-only audit mode"
  ],
  "publicApiSurface": [
    "useSGSIStore.login(email, password)",
    "useSGSIStore.logout()",
    "useSGSIStore.switchTenant(tenantId)",
    "useSGSIStore.addTenant(name)",
    "useSGSIStore.updateRequirementState(reqId, data)",
    "useSGSIStore.getRequirementState(reqId)",
    "useSGSIStore.getClauseProgress(clauseId)",
    "useSGSIStore.getSubclauseProgress(subclauseId)",
    "useSGSIStore.getGlobalCompliance()",
    "useSGSIStore.getMaturityScore()",
    "useSGSIStore.getDomainProgress()",
    "useSGSIStore.getClauseMaturity(clauseId)",
    "useSGSIStore.updateControlStatus(id, newStatus)",
    "useSGSIStore.addAsset(asset)",
    "useSGSIStore.updateAsset(id, updatedData)",
    "useSGSIStore.deleteAsset(id)",
    "useSGSIStore.addRisk(riskData)",
    "useSGSIStore.addAuditFinding(finding)",
    "useSGSIStore.addEvidence(evidence)",
    "useSGSIStore.deleteEvidence(id)",
    "useSGSIStore.addFinding(finding)",
    "useSGSIStore.updateFinding(id, data)",
    "useSGSIStore.closeFinding(id)",
    "generateExecutiveReport(options)",
    "generateSoAPDF(controls)"
  ]
